<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Package visibility: see launchable (LAUNCHER) apps for blacklist -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nothing120hzUnlock">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground overlay service -->
        <service
            android:name=".FloatingService"
            android:enabled="true"
            android:exported="false" />

        <!-- BootReceiver -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Quick Settings tile -->
        <service
            android:name=".OverlayTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- ONE Accessibility Service that does BOTH:
             - permission prompt auto-pause (régi funkció)
             - foreground app reporting for blacklist (új funkció) -->
        <service
            android:name=".PermissionWatcherService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/permission_watcher_config" />
        </service>

        <!-- PolicyReceiver: start/stop overlay based on rules -->
        <receiver
            android:name=".policy.PolicyReceiver"
            android:exported="false">
            <intent-filter>
                <!-- Battery Saver mode toggled -->
                <action android:name="android.os.action.POWER_SAVE_MODE_CHANGED" />
                <!-- Power connected/disconnected (nice trigger for re-eval) -->
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
                <!-- Foreground app changed (from Accessibility) -->
                <action android:name="com.nothing120hzunlock.TOP_APP_CHANGED" />
                <!-- Manual re-eval from UI -->
                <action android:name="com.nothing120hzunlock.ACTION_EVAL_POLICY" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
