<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- Tartalom (lapok) görgethetően -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <!-- KÖZÖS padding minden oldalnak -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="80dp"
            android:paddingBottom="96dp">

            <!-- PAGE 1: Welcome -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/pageWelcome"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/titleWelcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nothingdot"
                    android:text="Nothing 120Hz Unlock"
                    android:textStyle="bold"
                    android:textSize="24sp"
                    android:textColor="?android:attr/textColorPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/descWelcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="This app helps you keep 120Hz enabled on your Nothing phone using a tiny invisible overlay."
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    app:layout_constraintTop_toBottomOf="@id/titleWelcome"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- START gomb – alul középen -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="96dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Start setup"
                    app:cornerRadius="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- PAGE 2: Permissions -->
            <LinearLayout
                android:id="@+id/pagePermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/titlePermissions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Required permissions"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:fontFamily="@font/nothingdot" />

                <!-- USAGE ACCESS card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Usage Access" />

                            <TextView
                                android:id="@+id/statusUsage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❓"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Needed for Blacklist (optional)."
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="13sp" />

                        <!-- GOMBSOR: baseline fix -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:baselineAligned="false"
                            android:gravity="center_vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGrantUsage"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="Grant usage access"
                                app:cornerRadius="16dp" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDeclineUsage"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="No thanks"
                                app:cornerRadius="16dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BATTERY OPT EXCEPTION card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Battery optimization exception" />

                            <TextView
                                android:id="@+id/statusBattery"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❓"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Recommended to avoid system kills (optional)."
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="13sp" />

                        <!-- GOMBSOR: baseline fix -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:baselineAligned="false"
                            android:gravity="center_vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGrantBattery"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="Grant exception"
                                app:cornerRadius="16dp" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDeclineBattery"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="No thanks"
                                app:cornerRadius="16dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- OVERLAY (REQUIRED) card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Display over other apps (REQUIRED)" />

                            <TextView
                                android:id="@+id/statusOverlay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="❓"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Without this, the app cannot function."
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="13sp" />

                        <!-- GOMBSOR: baseline fix -->
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:baselineAligned="false"
                            android:gravity="center_vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGrantOverlay"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="Grant overlay permission"
                                app:cornerRadius="16dp" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="0dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDeclineOverlay"
                                style="@style/Widget.Material3.Button.TonalButton"
                                android:layout_width="0dp"
                                android:layout_height="64dp"
                                android:layout_weight="1"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="No thanks"
                                app:cornerRadius="16dp" />
                        </LinearLayout>

                        <!-- 10. visszautasítás után ezt mutatjuk -->
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/txtOverlayLeave"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:layout_marginTop="8dp"
                            android:text="Leave me alone."
                            android:textAlignment="center"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorSecondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- PAGE 3: Done -->
            <LinearLayout
                android:id="@+id/pageDone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setup complete"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:fontFamily="@font/nothingdot" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Setup finished successfully! You can adjust permissions later in the Permissions tab.

Tip: Enable “Disable default frame rate for games” in Developer Options — this app wouldn’t work without it."
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Alsó navigáció (Back/Next) – az 1. oldalon a Next rejtett -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:background="@android:color/transparent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:visibility="invisible"
            app:cornerRadius="16dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next"
            android:visibility="gone"
            app:cornerRadius="16dp" />
    </LinearLayout>

</FrameLayout>
